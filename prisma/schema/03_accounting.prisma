// ACCOUNTING MODULE
model Account {
  id                   String                @id @default(cuid())
  code                 String                @unique
  name                 String
  type                 AccountType
  normalBalance        NormalBalance         @default(debit)
  isPosting            Boolean               @default(true)
  level                Int                   @default(0)
  parentId             String?
  parent               Account?              @relation("AccountHierarchy", fields: [parentId], references: [id])
  children             Account[]             @relation("AccountHierarchy")
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  journalEntryLines    JournalEntryLine[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  salesInvoiceItems    SalesInvoiceItem[]
  defaultAccounts      DefaultAccount[]
  budgetItems          BudgetItem[]

  // Asset Module Relations
  assetCategoryAssets           AssetCategory[] @relation("AssetAccount")
  assetCategoryAccumDep         AssetCategory[] @relation("AccumDepAccount")
  assetCategoryDepExpense       AssetCategory[] @relation("DepExpenseAccount")

  // Cash & Bank Relations
  cashAccount                CashAccount?
  cashTransactionAllocations CashTransactionAllocation[]

  @@index([code])
  @@index([type])
  @@index([parentId])
}

model JournalEntry {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  entryNumber     String             @unique
  transactionDate DateTime
  description     String?
  status          EntryStatus        @default(draft)
  postedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  lines           JournalEntryLine[]
  attachments     File[]
  notes           String?

  // Cash & Bank Relations
  cashTransfer    CashTransfer?
  cashTransaction CashTransaction?
  purchasePayment PurchasePayment?
  salesPayment    SalesPayment?
  purchaseInvoice PurchaseInvoice?
  salesInvoice    SalesInvoice?

  // Asset Module Relations
  depreciationSchedule DepreciationSchedule?
  assetDisposal        AssetDisposal?

  // Payroll Module Relations
  payrollRun           PayrollRun?

  @@index([transactionDate])
  @@index([status])
  @@index([userId])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debitAmount    Decimal      @default(0)
  creditAmount   Decimal      @default(0)
  runningBalance Decimal?
  description    String?
  lineNumber     Int

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@index([contactId])
}

model DefaultAccount {
  id        String                @id @default(cuid())
  accountId String
  account   Account               @relation(fields: [accountId], references: [id])
  purpose   DefaultAccountPurpose
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([purpose])
  @@index([accountId])
}

enum DefaultAccountPurpose {
  ACCOUNTS_RECEIVABLE
  ACCOUNTS_PAYABLE
  GOODS_RECEIVED_NOT_INVOICED
  INVENTORY_ASSET
  COGS
  SALES_REVENUE
  SALES_DISCOUNT
  SALES_TAX_PAYABLE
  PURCHASE_TAX_RECEIVABLE
  CASH_ON_HAND
  BANK
  OPENING_BALANCE_EQUITY
  RETAINED_EARNINGS
  UNCATEGORIZED_EXPENSE
  UNCATEGORIZED_INCOME
  UNCATEGORIZED_ASSET
  EXCHANGE_GAIN_LOSS
  SALARIES_EXPENSE
  PAYROLL_LIABILITY
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum NormalBalance {
  debit
  credit
}

enum EntryStatus {
  draft
  posted
}
