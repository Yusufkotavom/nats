enum IntegrationEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD
}

model IntegrationOutbox {
  id            String                 @id @default(cuid())
  topic         String
  type          String
  aggregateType String
  aggregateId   String
  payload       Json

  status       IntegrationEventStatus @default(PENDING)
  attempts     Int                   @default(0)
  lockedAt     DateTime?
  lockedBy     String?
  processedAt  DateTime?
  nextAttemptAt DateTime?
  lastError    String?
  deadAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([type, createdAt])
  @@index([aggregateType, aggregateId])
}

model IntegrationInbox {
  id         String   @id @default(cuid())
  consumer   String
  outboxId   String
  processedAt DateTime @default(now())

  @@unique([consumer, outboxId])
  @@index([consumer, processedAt])
}
