// POS MODULE

model POSSession {
  id            String @id @default(cuid())
  sessionNumber String @unique

  cashierId String

  startTime DateTime         @default(now())
  endTime   DateTime?
  status    POSSessionStatus @default(OPEN)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  openingCash Decimal  @default(0)
  closingCash Decimal? // Calculated system total
  actualCash  Decimal? // Counted by cashier
  difference  Decimal?

  notes String?

  salesOrders   SalesOrder[]
  salesInvoices SalesInvoice[]
  salesPayments SalesPayment[]
  heldOrders    HeldOrder[]
  restaurantOrders RestaurantOrder[]
  serviceOrders POSServiceOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum POSSessionStatus {
  OPEN
  CLOSED
}

model HeldOrder {
  id        String   @id @default(cuid())
  holdId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String

  customerId   String?
  customer     Contact? @relation(fields: [customerId], references: [id])
  customerName String?

  items       Json
  totalAmount Decimal

  note        String?
  serviceType POSServiceType @default(DINE_IN)

  diningSpotId String?
  diningSpot   DiningSpot? @relation(fields: [diningSpotId], references: [id])

  posSessionId String?
  posSession   POSSession? @relation(fields: [posSessionId], references: [id])
}

model DiningArea {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spots DiningSpot[]
}

model DiningSpot {
  id        String           @id @default(cuid())
  areaId    String
  area      DiningArea       @relation(fields: [areaId], references: [id], onDelete: Cascade)
  spotCode  String           @unique
  spotName  String
  spotType  DiningSpotType   @default(TABLE)
  capacity  Int              @default(2)
  status    DiningSpotStatus @default(AVAILABLE)
  layoutX   Int?
  layoutY   Int?
  layoutW   Int?
  layoutH   Int?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  sessions   DiningSpotSession[]
  heldOrders HeldOrder[]
  restaurantOrders RestaurantOrder[]
  kitchenTickets KitchenTicket[]
}

model DiningSpotSession {
  id           String           @id @default(cuid())
  diningSpotId String
  diningSpot   DiningSpot       @relation(fields: [diningSpotId], references: [id], onDelete: Cascade)
  status       DiningSpotStatus @default(ORDERING)
  openedAt     DateTime         @default(now())
  closedAt     DateTime?
  openedBy     String
  closedBy     String?
  guestCount   Int?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum POSServiceType {
  DINE_IN
  TAKE_AWAY
  DELIVERY
}

enum DiningSpotType {
  TABLE
  ROOM
}

enum DiningSpotStatus {
  AVAILABLE
  ORDERING
  BILLING
  CLOSED
}

enum RestaurantOrderStatus {
  OPEN
  SENT_TO_KITCHEN
  BILLING
  PAID
  CLOSED
  CANCELLED
}

enum KitchenTicketStatus {
  NEW
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
}

enum KitchenItemStatus {
  NEW
  COOKING
  READY
  SERVED
  CANCELLED
}

enum POSFeeCategory {
  TAX
  FEE
}

enum POSFeeValueType {
  PERCENTAGE
  FIXED
}

enum POSServiceOrderStatus {
  NEW
  PROCESSING
  READY
  DONE
  CLOSED
  CANCELLED
}

model POSFeeSetting {
  id        String          @id @default(cuid())
  name      String
  category  POSFeeCategory  @default(FEE)
  valueType POSFeeValueType @default(FIXED)
  value     Decimal         @default(0)
  sortOrder Int             @default(0)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model POSServiceOrder {
  id            String                @id @default(cuid())
  orderNumber   String                @unique
  status        POSServiceOrderStatus @default(NEW)
  posSessionId  String
  posSession    POSSession            @relation(fields: [posSessionId], references: [id], onDelete: Cascade)
  contactId     String?
  salesOrderId  String
  salesInvoiceId String
  notes         String?
  subtotal      Decimal               @default(0)
  totalAmount   Decimal               @default(0)
  dpAmount      Decimal               @default(0)
  paidAmount    Decimal               @default(0)
  remainingAmount Decimal             @default(0)
  targetDate    DateTime?
  createdById   String
  processingAt  DateTime?
  readyAt       DateTime?
  doneAt        DateTime?
  closedAt      DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  items POSServiceOrderItem[]

  @@index([posSessionId, status])
  @@index([salesOrderId])
  @@index([salesInvoiceId])
}

model POSServiceOrderItem {
  id               String          @id @default(cuid())
  posServiceOrderId String
  posServiceOrder  POSServiceOrder @relation(fields: [posServiceOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productName      String
  quantity         Int
  unitPrice        Decimal
  discountAmount   Decimal         @default(0)
  totalPrice       Decimal
  hasActiveBom     Boolean         @default(false)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([posServiceOrderId])
  @@index([productId])
}

model RestaurantOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique
  status      RestaurantOrderStatus @default(OPEN)

  diningSpotId String
  diningSpot   DiningSpot @relation(fields: [diningSpotId], references: [id], onDelete: Cascade)

  posSessionId String
  posSession   POSSession @relation(fields: [posSessionId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  salesInvoiceId String?      @unique
  salesInvoice   SalesInvoice? @relation(fields: [salesInvoiceId], references: [id])

  notes String?

  subtotal       Decimal @default(0)
  itemDiscount   Decimal @default(0)
  globalDiscount Decimal @default(0)
  totalTax       Decimal @default(0)
  totalFees      Decimal @default(0)
  totalAmount    Decimal @default(0)

  sentToKitchenAt DateTime?
  billedAt        DateTime?
  paidAt          DateTime?
  closedAt        DateTime?

  createdById String

  items         RestaurantOrderItem[]
  kitchenTickets KitchenTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([diningSpotId, status])
  @@index([posSessionId, status])
}

model RestaurantOrderItem {
  id                String          @id @default(cuid())
  restaurantOrderId String
  restaurantOrder   RestaurantOrder @relation(fields: [restaurantOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  orderedQuantity Int
  servedQuantity  Int @default(0)
  unitPrice       Decimal
  discountAmount  Decimal @default(0)
  note            String?

  kitchenItems KitchenTicketItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantOrderId])
}

model KitchenTicket {
  id                String             @id @default(cuid())
  ticketNumber      String             @unique
  restaurantOrderId String
  restaurantOrder   RestaurantOrder    @relation(fields: [restaurantOrderId], references: [id], onDelete: Cascade)
  diningSpotId      String
  diningSpot        DiningSpot         @relation(fields: [diningSpotId], references: [id], onDelete: Cascade)
  status            KitchenTicketStatus @default(NEW)
  notes             String?
  sentAt            DateTime           @default(now())
  completedAt       DateTime?

  items KitchenTicketItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([diningSpotId, status])
  @@index([restaurantOrderId, status])
}

model KitchenTicketItem {
  id                    String            @id @default(cuid())
  kitchenTicketId       String
  kitchenTicket         KitchenTicket     @relation(fields: [kitchenTicketId], references: [id], onDelete: Cascade)
  restaurantOrderItemId String?
  restaurantOrderItem   RestaurantOrderItem? @relation(fields: [restaurantOrderItemId], references: [id], onDelete: SetNull)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  station  String
  status   KitchenItemStatus @default(NEW)
  note     String?
  startedAt DateTime?
  readyAt   DateTime?
  servedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kitchenTicketId, station])
  @@index([status, station])
}
