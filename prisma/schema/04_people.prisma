// VENDOR AND CUSTOMER MODULE
model Customer {
    id        String   @id @default(cuid())
    name      String
    email     String?
    phone     String?
    address   String?
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Vendor {
    id        String   @id @default(cuid())
    name      String
    email     String?
    phone     String?
    address   String?
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
