// GENERAL TABLE
model CompanyProfile {
  id                       String   @id @default(cuid())
  name                     String
  address                  String?
  phone                    String?
  email                    String?
  website                  String?
  taxId                    String?
  currency                 String   @default("USD")
  currencySymbol           String   @default("$")
  dateFormat               String   @default("MM/dd/yyyy")
  currencyFormat           String   @default("standard")
  locale                   String   @default("en-US")
  timezone                 String   @default("UTC")
  posProductVisibilityMode String   @default("POS_ONLY") // POS_ONLY | ALL_ACTIVE
  posServiceChargePercent  Decimal  @default(0)
  posTaxPercent            Decimal  @default(0)
  posAdditionalFeeAmount   Decimal  @default(0)
  posAdditionalFeeLabel    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AuditLog {
  id     String @id @default(cuid())
  userId String

  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model File {
  id           String  @id @default(cuid())
  name         String
  url          String
  mimeType     String
  size         Int
  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  journalEntryId    String?
  journalEntry      JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  purchasePaymentId String?
  purchasePayment   PurchasePayment? @relation(fields: [purchasePaymentId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  purchaseReturnId  String?
  purchaseReturn    PurchaseReturn?  @relation(fields: [purchaseReturnId], references: [id])
  purchaseReceiveId String?
  purchaseReceive   PurchaseReceive? @relation(fields: [purchaseReceiveId], references: [id])
  salesPaymentId    String?
  salesPayment      SalesPayment?    @relation(fields: [salesPaymentId], references: [id])
  salesOrderId      String?
  salesOrder        SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  salesInvoiceId    String?
  salesInvoice      SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  salesReturnId     String?
  salesReturn       SalesReturn?     @relation(fields: [salesReturnId], references: [id])
  salesShipmentId   String?
  salesShipment     SalesShipment?   @relation(fields: [salesShipmentId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([uploadedById])
}

model DocumentNumbering {
  id              String    @id @default(cuid())
  entityType      String    @unique
  name            String
  prefix          String    @default("")
  suffix          String    @default("")
  includeYear     Boolean   @default(true)
  yearFormat      String    @default("YY") // "YY" or "YYYY"
  includeMonth    Boolean   @default(true)
  sequenceDigits  Int       @default(4)
  currentSequence Int       @default(0)
  resetYearly     Boolean   @default(true)
  resetMonthly    Boolean   @default(false)
  lastGeneratedAt DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([entityType])
}

model TenantTransactionMonthly {
  id        String   @id @default(cuid())
  yearMonth String   @unique // Format: "YYYY-MM"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  name          String
  roleId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role  Role   @relation(fields: [roleId], references: [id])
  files File[]
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}
