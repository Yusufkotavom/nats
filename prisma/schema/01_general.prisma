// GENERAL TABLE
model CompanyProfile {
  id             String   @id @default(cuid())
  name           String
  address        String?
  phone          String?
  email          String?
  website        String?
  taxId          String?
  currency       String   @default("USD")
  currencySymbol String   @default("$")
  dateFormat     String   @default("MM/dd/yyyy")
  currencyFormat String   @default("standard")
  locale         String   @default("en-US")
  timezone       String   @default("UTC")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  journalEntries JournalEntry[]
  files          File[]
  approvedMovements InventoryMovement[] @relation("MovementApprover")
  
  // Purchase Order Relations
  createdPurchaseOrders   PurchaseOrder[] @relation("POCreatedBy")
  updatedPurchaseOrders   PurchaseOrder[] @relation("POUpdatedBy")
  issuedPurchaseOrders    PurchaseOrder[] @relation("POIssuedBy")
  closedPurchaseOrders    PurchaseOrder[] @relation("POClosedBy")
  cancelledPurchaseOrders PurchaseOrder[] @relation("POCancelledBy")

  // Sales Order Relations
  createdSalesOrders   SalesOrder[] @relation("SOCreatedBy")
  updatedSalesOrders   SalesOrder[] @relation("SOUpdatedBy")
  confirmedSalesOrders SalesOrder[] @relation("SOConfirmedBy")
  closedSalesOrders    SalesOrder[] @relation("SOClosedBy")
  cancelledSalesOrders SalesOrder[] @relation("SOCancelledBy")

  // POS Relations
  posSessions POSSession[]
  heldOrders  HeldOrder[]
  reportLogs  ReportLog[]
  aiSessions  AISession[]
  aiUsages    AIUsage[]

  // Department & Project Management
  managedDepartments Department[] @relation("DepartmentManager")
  managedProjects    Project[]    @relation("ProjectManager")

  // Budgeting Relations
  createdBudgets   Budget[]         @relation("BudgetCreator")
  revisedBudgets   BudgetRevision[] @relation("BudgetReviser")
  approvedBudgets  BudgetApproval[] @relation("BudgetApprover")

  @@index([email])
  @@index([roleId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model File {
  id             String        @id @default(cuid())
  name           String
  url            String
  mimeType       String
  size           Int
  uploadedById   String?
  uploadedBy     User?         @relation(fields: [uploadedById], references: [id])
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  purchasePaymentId String?
  purchasePayment   PurchasePayment? @relation(fields: [purchasePaymentId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  purchaseReturnId  String?
  purchaseReturn    PurchaseReturn?  @relation(fields: [purchaseReturnId], references: [id])
  purchaseReceiveId String?
  purchaseReceive   PurchaseReceive? @relation(fields: [purchaseReceiveId], references: [id])
  salesPaymentId    String?
  salesPayment      SalesPayment?    @relation(fields: [salesPaymentId], references: [id])
  salesOrderId      String?
  salesOrder        SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  salesInvoiceId    String?
  salesInvoice      SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  salesReturnId     String?
  salesReturn       SalesReturn?     @relation(fields: [salesReturnId], references: [id])
  salesShipmentId   String?
  salesShipment     SalesShipment?   @relation(fields: [salesShipmentId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([uploadedById])
}
