// SALES MODULE

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_SHIPPED
  SHIPPED
  CLOSED
  CANCELLED
}

model SalesOrder {
  id           String           @id @default(cuid())
  orderNumber  String           @unique
  contactId    String
  contact      Contact          @relation(fields: [contactId], references: [id])
  orderDate    DateTime         @default(now())
  expectedDate DateTime?
  status       SalesOrderStatus @default(DRAFT)
  totalAmount  Decimal          @default(0)
  notes        String?

  // Financial details
  subtotal       Decimal @default(0)
  taxAmount      Decimal @default(0)
  discountAmount Decimal @default(0)

  items     SalesOrderItem[]
  shipments SalesShipment[]
  invoices  SalesInvoice[]
  returns   SalesReturn[]

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Status Tracking
  createdById String?
  createdBy   User?   @relation("SOCreatedBy", fields: [createdById], references: [id])

  updatedById String?
  updatedBy   User?   @relation("SOUpdatedBy", fields: [updatedById], references: [id])

  confirmedAt   DateTime?
  confirmedById String?
  confirmedBy   User?     @relation("SOConfirmedBy", fields: [confirmedById], references: [id])

  closedAt   DateTime?
  closedById String?
  closedBy   User?     @relation("SOClosedBy", fields: [closedById], references: [id])

  cancelledAt   DateTime?
  cancelledById String?
  cancelledBy   User?     @relation("SOCancelledBy", fields: [cancelledById], references: [id])

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  // POS Relation
  posSessionId String?
  posSession   POSSession? @relation(fields: [posSessionId], references: [id])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  quantity        Int
  shippedQuantity Int     @default(0)
  unitPrice       Decimal
  totalPrice      Decimal

  taxRate   Decimal  @default(0)
  taxRateId String?
  taxRule   TaxRate? @relation(fields: [taxRateId], references: [id])

  discountRate Decimal @default(0)

  shipmentItems SalesShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SalesShipmentStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model SalesShipment {
  id             String      @id @default(cuid())
  shipmentNumber String      @unique
  salesOrderId   String?
  salesOrder     SalesOrder? @relation(fields: [salesOrderId], references: [id])
  contactId      String
  contact        Contact     @relation(fields: [contactId], references: [id])

  shipmentDate   DateTime            @default(now())
  status         SalesShipmentStatus @default(DRAFT)
  notes          String?
  trackingNumber String?
  carrier        String?

  items SalesShipmentItem[]

  inventoryMovementId String?

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesShipmentItem {
  id              String        @id @default(cuid())
  salesShipmentId String
  salesShipment   SalesShipment @relation(fields: [salesShipmentId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  salesOrderItemId String?
  salesOrderItem   SalesOrderItem? @relation(fields: [salesOrderItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SalesInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  OVERDUE
}

model SalesInvoice {
  id            String  @id @default(cuid())
  invoiceNumber String  @unique
  contactId     String
  contact       Contact @relation(fields: [contactId], references: [id])

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])

  invoiceDate DateTime
  dueDate     DateTime
  status      SalesInvoiceStatus @default(DRAFT)
  totalAmount Decimal            @default(0)
  balanceDue  Decimal            @default(0)

  // Additional financials
  subtotal       Decimal @default(0)
  globalDiscount Decimal @default(0)
  totalTax       Decimal @default(0)
  shippingCost   Decimal @default(0)

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  notes String?
  terms String?

  items    SalesInvoiceItem[]
  returns  SalesReturn[]
  payments SalesPayment[]

  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  attachments File[]

  // POS Relation
  posSessionId String?
  posSession   POSSession? @relation(fields: [posSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesInvoiceItem {
  id             String       @id @default(cuid())
  salesInvoiceId String
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id])

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal
  totalPrice  Decimal

  // Additional financials
  discount Decimal @default(0)
  tax      Decimal @default(0)

  taxRateId       String?
  taxRule         TaxRate? @relation(fields: [taxRateId], references: [id])
  taxRateSnapshot Decimal?

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesPayment {
  id            String @id @default(cuid())
  paymentNumber String @unique
  contactId     String

  // POS Relation
  posSessionId String?
  posSession   POSSession? @relation(fields: [posSessionId], references: [id])
  contact      Contact     @relation(fields: [contactId], references: [id])

  salesInvoiceId String
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id])

  paymentDate DateTime @default(now())
  amount      Decimal
  reference   String?
  notes       String?
  method      String? // e.g., "CASH", "BANK_TRANSFER", "CHECK"

  // Link to Cash/Bank Account
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])

  // Link to Journal Entry
  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SalesReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

model SalesReturn {
  id           String  @id @default(cuid())
  returnNumber String  @unique
  contactId    String
  contact      Contact @relation(fields: [contactId], references: [id])

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])

  salesInvoiceId String?
  salesInvoice   SalesInvoice? @relation(fields: [salesInvoiceId], references: [id])

  returnDate  DateTime          @default(now())
  status      SalesReturnStatus @default(DRAFT)
  reason      String?
  notes       String?
  totalAmount Decimal           @default(0)

  items SalesReturnItem[]

  inventoryMovementId String?

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesReturnItem {
  id            String      @id @default(cuid())
  salesReturnId String
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity   Int
  unitPrice  Decimal
  totalPrice Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
