// PURCHASING MODULE

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  CLOSED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNumber  String              @unique
  contactId    String
  contact      Contact             @relation(fields: [contactId], references: [id])
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Decimal             @default(0)
  notes        String?

  items    PurchaseOrderItem[]
  receives PurchaseReceive[]
  invoices PurchaseInvoice[]
  returns  PurchaseReturn[]

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Status Tracking
  createdById String?

  updatedById String?

  issuedAt   DateTime?
  issuedById String?

  closedAt   DateTime?
  closedById String?

  cancelledAt   DateTime?
  cancelledById String?

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantity         Int
  receivedQuantity Int     @default(0)
  unitCost         Decimal
  totalCost        Decimal

  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])
  taxRateSnapshot Decimal?

  receiveItems PurchaseReceiveItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchasePayment {
  id            String  @id @default(cuid())
  paymentNumber String  @unique
  contactId     String
  contact       Contact @relation(fields: [contactId], references: [id])

  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])

  paymentDate DateTime @default(now())
  amount      Decimal
  reference   String?
  notes       String?

  // Link to Cash/Bank Account
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])

  // Link to Journal Entry
  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PurchaseReceiveStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model PurchaseReceive {
  id              String         @id @default(cuid())
  receiveNumber   String         @unique
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  contactId       String
  contact         Contact        @relation(fields: [contactId], references: [id])

  receiveDate DateTime              @default(now())
  status      PurchaseReceiveStatus @default(DRAFT)
  notes       String?

  items PurchaseReceiveItem[]

  inventoryMovementId String?

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseReceiveItem {
  id                String          @id @default(cuid())
  purchaseReceiveId String
  purchaseReceive   PurchaseReceive @relation(fields: [purchaseReceiveId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  purchaseOrderItemId String?
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PurchaseInvoiceStatus {
  DRAFT
  BILLED
  PARTIALLY_PAID
  PAID
  CANCELED
}

model PurchaseInvoice {
  id            String  @id @default(cuid())
  invoiceNumber String
  contactId     String
  contact       Contact @relation(fields: [contactId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  invoiceDate DateTime
  dueDate     DateTime
  status      PurchaseInvoiceStatus @default(DRAFT)
  totalAmount Decimal               @default(0)

  // Additional financials
  globalDiscount Decimal @default(0)
  totalTax       Decimal @default(0)
  shippingCost   Decimal @default(0)
  handlingCost   Decimal @default(0)

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  notes String?

  items    PurchaseInvoiceItem[]
  returns  PurchaseReturn[]
  payments PurchasePayment[]

  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, invoiceNumber])
}

model PurchaseInvoiceItem {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal
  totalPrice  Decimal

  // Additional financials
  discount Decimal @default(0)
  tax      Decimal @default(0)

  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])
  taxRateSnapshot Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  account   Account? @relation(fields: [accountId], references: [id])
  accountId String?
}

enum PurchaseReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

model PurchaseReturn {
  id           String  @id @default(cuid())
  returnNumber String  @unique
  contactId    String
  contact      Contact @relation(fields: [contactId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])

  returnDate  DateTime             @default(now())
  status      PurchaseReturnStatus @default(DRAFT)
  reason      String?
  notes       String?
  totalAmount Decimal              @default(0)

  items PurchaseReturnItem[]

  inventoryMovementId String?

  // Budgeting
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])

  attachments File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseReturnItem {
  id               String         @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity   Int
  unitPrice  Decimal
  totalPrice Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
