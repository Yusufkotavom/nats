// INVENTORY MODULE
model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  symbol    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productsBase     Product[] @relation("BaseUnit")
  productsPurchase Product[] @relation("PurchaseUnit")
  productsSales    Product[] @relation("SalesUnit")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  sku         String    @unique
  name        String
  description String?
  image       String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  price       Decimal   @default(0)
  cost        Decimal   @default(0)
  averageCost Decimal   @default(0) // Valuation: Moving Average Cost
  minStock    Int       @default(0)

  // UOM Configuration
  baseUnitId String?
  baseUnit   Unit?   @relation("BaseUnit", fields: [baseUnitId], references: [id])

  purchaseUnitId           String?
  purchaseUnit             Unit?   @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id])
  purchaseConversionFactor Decimal @default(1)

  salesUnitId           String?
  salesUnit             Unit?   @relation("SalesUnit", fields: [salesUnitId], references: [id])
  salesConversionFactor Decimal @default(1)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  inventory Inventory[]
  movements InventoryMovement[]

  // Pricing & Discounts
  priceHistory             PriceHistory[]
  discounts                Discount[]
  inventoryMovementDetails InventoryMovementDetail[]

  purchaseOrderItems   PurchaseOrderItem[]
  purchaseReceiveItems PurchaseReceiveItem[]
  purchaseReturnItems  PurchaseReturnItem[]

  salesOrderItems    SalesOrderItem[]
  salesShipmentItems SalesShipmentItem[]
  salesInvoiceItems  SalesInvoiceItem[]
  salesReturnItems   SalesReturnItem[]

  @@index([categoryId])
  @@index([sku])
}

model PriceHistory {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  price         Decimal
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([productId])
}

model Discount {
  id          String       @id @default(cuid())
  code        String       @unique
  description String?
  type        DiscountType
  value       Decimal
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean      @default(true)
  minQuantity Int?
  priority    Int          @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Warehouse {
  id            String              @id @default(cuid())
  name          String              @unique
  location      String?
  inventory     Inventory[]
  fromMovements InventoryMovement[] @relation("FromWarehouse")
  toMovements   InventoryMovement[] @relation("ToWarehouse")

  posSessions POSSession[]

  locations Location[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id          String       @id @default(cuid())
  name        String
  code        String
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  type        LocationType @default(STORAGE)
  inventory   Inventory[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([warehouseId, code])
}

enum LocationType {
  STORAGE
  RECEIVING
  SHIPPING
  RETURN
  QUARANTINE
  PICKING
}

model Inventory {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  // Storage Hierarchy
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  // Stock Levels
  quantity          Int @default(0) // Physical On-Hand
  quantityAllocated Int @default(0) // Soft Reserved (Committed to Orders)
  quantityReserved  Int @default(0) // Hard Reserved (e.g. Quarantine)

  // Valuation Layer (Snapshot for FIFO/Specific ID)
  unitCost Decimal @default(0)

  reorderPoint Int       @default(10)
  // location     String? // Deprecated in favor of locationId, kept for migration
  batchNumber  String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Updated constraint: If location is used, we need to be careful.
  // Ideally: @@unique([productId, locationId, batchNumber])
  // But for backward compatibility with existing "Warehouse Level" logic:
  @@unique([productId, warehouseId, batchNumber])
  @@index([productId])
  @@index([warehouseId])
  @@index([locationId])
}

model InventoryMovement {
  id              String         @id @default(cuid())
  type            MovementType
  reference       String?
  notes           String?
  status          MovementStatus @default(PENDING)
  transactionDate DateTime       @default(now())

  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])

  details InventoryMovementDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  approvedById String?

  approvedAt      DateTime?
  rejectionReason String?

  @@index([type])
  @@index([transactionDate])
}

model InventoryMovementDetail {
  id                  String            @id @default(cuid())
  inventoryMovementId String
  inventoryMovement   InventoryMovement @relation(fields: [inventoryMovementId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitCost  Decimal @default(0) // Recorded Cost at time of movement
  notes     String?

  // Item specific details
  batchNumber String? // Inventory Batch Number

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([inventoryMovementId])
}

enum MovementType {
  IN // Purchase Receive
  OUT // Sales Shipment
  TRANSFER // Warehouse Transfer
  ADJUSTMENT // Stock Adjustment
}

enum MovementStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}
